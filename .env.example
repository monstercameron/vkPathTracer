# Optional local defaults. Copy to .env and edit; .env is git-ignored.
# Existing process environment variables override values from this file.

PTAPP_BACKEND=d3d12
PTAPP_PLATFORM=qt
PTAPP_SCENE=assets/scenes/cornell_native.json
PTAPP_RENDER_WIDTH=960
PTAPP_RENDER_HEIGHT=540
PTAPP_MAX_DEPTH=2
PTAPP_UI_PRESENT_HZ=60

# Qt GUI builds do not open a terminal by default. Set to true only when needed.
PTAPP_CONSOLE=false

# D3D12 runtime tuning.
PT_D3D12_RAYS_PER_PIXEL=8
PT_D3D12_READBACK_INTERVAL=4
